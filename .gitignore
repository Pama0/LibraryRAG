__pycache__/
*.py[cod]
*.egg-info/
dist/
build/

# 虚拟环境
.venv/

# IDE
.idea/
.vscode/
*.swp

# 向量数据库（运行时生成）
chroma_db/
chroma_db_single_test/
core/rag/chroma/
storage/

# 已退役的法条语料（项目转 book-only，法条入 legacy；不随仓库分发）
data/legal_documents/

# SQLite 数据库（运行时生成）
*.db

# 运行时日志
logs/

# workflow 可视化产物（脚本生成，随时重生）
docs/workflow_diagrams/

# ablation 评测产物（脚本和 questions.json 保留，结果不提交）
eval/ablation_results.json
eval/ablation_report.md

# 上传的书籍 PDF 数据（运行时生成，体积大）
data/books/*
!data/books/.gitkeep

# 前端依赖与构建产物
node_modules/
frontend/dist/
frontend/.vite/
frontend/tsconfig.tsbuildinfo

# 临时文件
temp_data/
test_data/

# 学习/实验代码
workflow_learn/

# 本地启动脚本
*.bat

# Claude Code 本地配置
.claude/
CLAUDE.md

